{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevKit",
  "version": "0.1.0",
  "identifier": "os.devkit",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DevKit",
        "width": 1000,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "app",
      "nsis",
      "msi",
      "deb",
      "appimage",
      "rpm"
    ],
    "createUpdaterArtifacts": true,
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "linux": {
      "deb": {},
      "appimage": {},
      "rpm": {}
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFFNzQ0NUNEQkM4RkM2NTcKUldSWHhvKzh6VVYwSHNpVVRVdHpwMUN4OUhka0F5WDEwd2pnQmR5YlJNNE1MTlk5WmdCY1RTQlkK",
      "endpoints": [
        "https://github.com/9527-tb/devkit/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
